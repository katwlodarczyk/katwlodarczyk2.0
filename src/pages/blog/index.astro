---
import Layout from "../../layouts/Layout.astro";
import BlogCard from "../../components/blog/BlogCard.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<Layout
  title="Blog — Kat Wlodarczyk"
  description="Thoughts on web development, design, and the tools I use day-to-day."
>
  <div class="max-w-5xl mx-auto px-4 md:px-6 py-12">
    <!-- Page header -->
    <div class="mb-10">
      <nav aria-label="Breadcrumb" class="mb-4 text-sm text-muted-foreground">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span class="mx-2">/</span>
        <span class="text-foreground">Blog</span>
      </nav>
      <h1 class="text-3xl md:text-4xl font-display text-foreground mb-3">
        <span aria-hidden="true">📖 </span><span class="text-highlight">Blog</span>
      </h1>
      <p class="text-lg text-muted-foreground">
        Thoughts on web development, design, and the tools I use day-to-day.
      </p>
    </div>

    <!-- Article grid -->
    {posts.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        {posts.map((post) => (
          <BlogCard
            title={post.data.title}
            date={post.data.date}
            excerpt={post.data.excerpt}
            category={post.data.category}
            slug={post.slug}
          />
        ))}
      </div>
    ) : (
      <p class="text-muted-foreground">No posts yet — check back soon!</p>
    )}
  </div>
</Layout>
