---
import Layout from "./Layout.astro";
import { personalInfo } from "../lib/data";
import { getCollection } from "astro:content";

const allPosts = await getCollection("blog");

interface Props {
  title: string;
  date: Date;
  excerpt: string;
  category: string;
  tags?: string[];
  slug: string;
  image?: string;
}

const { title, date, excerpt, category, tags = [], slug, image } = Astro.props;

const relatedPosts = allPosts
  .filter((p) => p.slug !== slug && p.data.category === category)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const formattedDate = date.toLocaleDateString("en-GB", {
  day: "numeric",
  month: "long",
  year: "numeric",
});
---

<Layout title={`${title} — Kat Wlodarczyk`} description={excerpt}>
  <div class="max-w-5xl mx-auto px-4 md:px-6 pb-0 md:pb-12 pt-12">
    <!-- Breadcrumb -->
    <nav aria-label="Breadcrumb" class="mb-8 text-sm text-muted-foreground">
      <a href="/" class="hover:text-primary transition-colors">Home</a>
      <span class="mx-2">/</span>
      <a href="/blog" class="hover:text-primary transition-colors">Blog</a>
      <span class="mx-2">/</span>
      <span class="text-foreground">{title}</span>
    </nav>

    <div class="flex flex-col lg:flex-row gap-6 md:gap-10">
    <!-- Featured image -->
        {image && (
          <div class="md:hidden rounded-2xl overflow-hidden border border-border">
            <img
              src={image}
              alt={title}
              class="w-full h-auto object-cover"
            />
          </div>
        )}
      <!-- Article body -->
      <article class="w-full lg:w-[70%]">
        <div class="bg-card rounded-2xl border border-border p-4 md:p-10">
          <!-- Category + date -->
          <div class="flex flex-wrap items-center gap-3 mb-4">
            <span class="px-3 py-1 text-xs font-medium rounded-full bg-secondary/15 text-foreground border border-secondary/40">
              {category}
            </span>
            <time datetime={date.toISOString().split("T")[0]} class="text-sm text-muted-foreground">
              {formattedDate}
            </time>
          </div>

          <h1 class="text-3xl md:text-4xl font-display mb-4 text-foreground">{title}</h1>
          <p class="text-lg text-muted-foreground mb-8 leading-relaxed">{excerpt}</p>

          {tags.length > 0 && (
            <div class="flex flex-wrap gap-2 mb-8">
              {tags.map((tag) => (
                <span class="px-2.5 py-1 text-xs rounded-full bg-primary/10 text-primary border border-primary/20">
                  #{tag}
                </span>
              ))}
            </div>
          )}

          <hr class="border-border mb-8" />

          <div class="prose-blog">
            <slot />
          </div>
        </div>

        <!-- Back to blog -->
        <div class="mt-8">
          <a
            href="/blog"
            class="inline-flex items-center gap-2 text-primary hover:text-accent transition-colors font-medium"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
            Back to Blog
          </a>
        </div>
      </article>

      <!-- Sidebar -->
      <aside class="w-full lg:w-[30%] lg:sticky lg:top-20 self-start space-y-6">
        <!-- Featured image -->
        {image && (
          <div class="hidden md:flex rounded-2xl overflow-hidden border border-border">
            <img
              src={image}
              alt={title}
              class="w-full h-auto object-cover"
            />
          </div>
        )}

        <!-- About card -->
        <div class="bg-card rounded-2xl border border-border p-5">
          <h2 class="text-sm font-semibold text-muted-foreground uppercase tracking-wider mb-3">About the author</h2>
          <div class="mb-3">
            <p class="font-semibold text-foreground text-sm">{personalInfo.name}</p>
            <p class="text-xs text-muted-foreground">Web Developer</p>
          </div>
          <p class="text-sm text-muted-foreground leading-relaxed">
            Creative web developer with a background in both design and code. Writing about web development, design, and the tools she uses day-to-day.
          </p>
        </div>

        <!-- Related posts -->
        {relatedPosts.length > 0 && (
          <div class="bg-card rounded-2xl border border-border p-5">
            <h2 class="text-sm font-semibold text-muted-foreground uppercase tracking-wider mb-4">Related posts</h2>
            <ul class="space-y-5">
              {relatedPosts.map((post) => (
                <li>
                  <a href={`/blog/${post.slug}`} class="group block">
                    <p class="text-sm font-medium text-foreground group-hover:text-primary transition-colors leading-snug line-clamp-2">
                      {post.data.title}
                    </p>
                    <p class="text-xs text-muted-foreground mt-1">
                      {post.data.date.toLocaleDateString("en-GB", { day: "numeric", month: "short", year: "numeric" })}
                    </p>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )}

      </aside>
    </div>
  </div>
</Layout>
