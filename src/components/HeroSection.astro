---
import { personalInfo } from "../lib/data";
---

<section id="hero" class="min-h-[85vh] flex items-center py-12 md:py-0">
  <div class="max-w-5xl mx-auto px-4 md:px-6 w-full">
    <div class="flex flex-col-reverse md:flex-row gap-10 md:gap-16 md:items-center">

      <!-- Image -->
      <div class="scroll-reveal flex-shrink-0 mx-auto md:mx-0 md:w-[42%]">
        <div class="relative rounded-2xl aspect-[3/4] sm:aspect-[4/3] md:aspect-[3/4]">
          <!-- Glow -->
          <div class="absolute inset-0 bg-gradient-to-b from-primary/20 to-secondary/15 blur-3xl scale-105 rounded-3xl dark:from-primary/50 dark:to-secondary/40"></div>
          <!-- Image -->
          <img
            src="/profile.jpg"
            alt="Kat Wlodarczyk"
            class="relative w-full h-full object-cover object-[25%] rounded-2xl"
          />
        </div>
      </div>

      <!-- Text -->
      <div class="flex-1 flex flex-col gap-6">
        <!-- Label pill -->
        <div class="scroll-reveal">
          <span class="inline-block px-4 py-1.5 text-xs font-medium rounded-full border border-primary/40 text-primary bg-primary/8 tracking-wide">
            Web Developer
          </span>
        </div>

        <!-- Heading -->
        <h1 class="scroll-reveal scroll-reveal-delay-1 text-5xl md:text-6xl font-display leading-tight text-foreground">
          Hey, I'm Kat.
        </h1>

        <!-- Bio -->
        <p class="scroll-reveal scroll-reveal-delay-2 text-base text-muted-foreground leading-relaxed">
          A smart creative with a background in both design and code. I hold a BSc in
          Digital Design and Web Development from Solent University and received the British
          Computer Society award for Digital Development. 
        </p>
        <p class="scroll-reveal scroll-reveal-delay-2 text-sm text-muted-foreground leading-relaxed">
        My passion for code started at age 11
        when I built my first custom blog with HTML and CSS. Outside of development, you'll
        find me training for my next run.
        </p>

        <!-- Social icons -->
        <div class="scroll-reveal scroll-reveal-delay-3 flex items-center gap-1 -ml-2">
          <a
            href={`mailto:${personalInfo.email}`}
            class="p-2 rounded-xl text-muted-foreground hover:text-primary transition-colors"
            aria-label="Email"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          </a>
          <a
            href={personalInfo.github}
            target="_blank"
            rel="noopener noreferrer"
            class="p-2 rounded-xl text-muted-foreground hover:text-primary transition-colors"
            aria-label="GitHub"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          </a>
          <a
            href={personalInfo.linkedin}
            target="_blank"
            rel="noopener noreferrer"
            class="p-2 rounded-xl text-muted-foreground hover:text-primary transition-colors"
            aria-label="LinkedIn"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
        </div>
      </div>

    </div>
  </div>
</section>
