---
import { personalInfo } from "../lib/data";
---

<section id="hero" class="pt-12 pb-16 md:pt-16">
  <div class="max-w-5xl mx-auto px-4 md:px-6">
    <div class="flex flex-col md:flex-row md:items-center gap-8 md:gap-12">
      <!-- Text content -->
      <div class="flex-1">
        <h1
          class="scroll-reveal text-4xl md:text-5xl font-display leading-tight mb-3 text-foreground"
         
        >
          Hi, I'm Kat Wlodarczyk <span aria-hidden="true" class="hidden">✨</span>
        </h1>
        <p
          class="scroll-reveal scroll-reveal-delay-1 text-xl text-muted-foreground font-medium mb-6"
         
        >Web Developer</p>

        <!-- Contact links -->
        <div
          class="scroll-reveal scroll-reveal-delay-2 flex flex-wrap -ml-2"
         
        >
          <a
            href={`mailto:${personalInfo.email}`}
            class="inline-flex items-center gap-2 p-2 rounded-xl text-foreground text-sm font-medium hover:border-primary/60 hover:text-primary transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            
          </a>
          <a
            href={personalInfo.github}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 p-2 rounded-xl text-foreground text-sm font-medium hover:border-primary/60 hover:text-primary transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
            
          </a>
          <a
            href={personalInfo.linkedin}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 p-2 rounded-xl text-foreground text-sm font-medium hover:border-primary/60 hover:text-primary transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            
          </a>
        </div>
      </div>

      <!-- Profile image -->
      <div
        class="scroll-reveal scroll-reveal-delay-1 flex-shrink-0 mx-auto md:mx-0"
       
      >
        <div class="relative w-64 h-80 md:w-80 md:h-100">
          <div class="absolute -inset-1 bg-gradient-to-r from-pink-500 to-purple-500 rounded-full blur opacity-30 group-hover:opacity-10 blur-xl"></div>
          <img
            src="/profile.jpg"
            alt="Kat Wlodarczyk"
            class="w-full h-full object-cover object-[25%] rounded-full relative ring-2 ring-purple-500/50"
          />
        </div>
      </div>
    </div>

    <!-- Bio -->
    <div class="prose text-lg text-foreground/85 leading-relaxed scroll-reveal scroll-reveal-delay-3 mt-16 bio-highlight">
      <p class="">
        A smart creative with a background in both design and code. I hold a BSc in
        Digital Design and Web Development from Solent University and received the British
        Computer Society award for Digital Development.
      </p> 
      <p>
        My passion for code started at age 11
        when I built my first custom blog with HTML and CSS. Outside of development, you'll
        find me training for my next run.
      </p>
    </div>
  </div>
</section>
