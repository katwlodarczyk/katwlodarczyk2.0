---
interface Props {
  title: string;
  date: Date;
  excerpt: string;
  category: string;
  slug: string;
}

const { title, date, excerpt, category, slug } = Astro.props;

const formattedDate = date.toLocaleDateString("en-GB", {
  day: "numeric",
  month: "long",
  year: "numeric",
});
---

<article class="bg-card rounded-2xl border border-border p-6 flex flex-col hover:border-primary/30 transition-colors group">
  <div class="flex items-center gap-3 mb-3">
    <span class="px-2.5 py-1 text-xs font-medium rounded-full bg-secondary/20 text-secondary-foreground border border-secondary/30">
      {category}
    </span>
    <time datetime={date.toISOString().split("T")[0]} class="text-xs text-muted-foreground">
      {formattedDate}
    </time>
  </div>

  <h2 class="text-lg font-display text-foreground mb-2 group-hover:text-primary transition-colors leading-snug">
    <a href={`/blog/${slug}`} class="focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring rounded">
      {title}
    </a>
  </h2>

  <p class="text-sm text-muted-foreground leading-relaxed flex-1 mb-4">{excerpt}</p>

  <a
    href={`/blog/${slug}`}
    class="inline-flex items-center gap-1 text-sm font-medium text-primary hover:text-accent transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring rounded"
    aria-label={`Read more: ${title}`}
  >
    Read more
    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
  </a>
</article>
