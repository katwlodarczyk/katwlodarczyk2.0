---
const navLinks = [
  { href: "/#experience", label: "Experience", emoji: "💼" },
  { href: "/#skills", label: "Skills", emoji: "🛠️" },
  { href: "/#awards", label: "Awards", emoji: "🏆" },
  { href: "/#education", label: "Education", emoji: "🎓" },
  { href: "/#projects", label: "Projects", emoji: "🚀" },
  { href: "/blog", label: "Blog", emoji: "📖" },
];

const currentPath = Astro.url.pathname;
---

<!-- Skip to content -->
<a
  href="#main-content"
  class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-50 focus:px-4 focus:py-2 focus:bg-primary focus:text-primary-foreground focus:rounded-lg focus:text-sm"
>
  Skip to main content
</a>

<header
  x-data="{ open: false }"
  class="sticky top-0 z-50 w-full backdrop-blur-md bg-background/80 border-b border-border/50 transition-colors duration-300"
>
  <div class="max-w-5xl mx-auto px-4 md:px-6">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a
        href="/"
        class="font-display font-bold text-lg text-foreground hover:text-primary transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring rounded"
      >
        Kat Wlodarczyk
      </a>

      <!-- Desktop nav -->
      <nav aria-label="Main navigation" class="hidden md:flex items-center gap-1">
        {navLinks.map(({ href, label, emoji }) => (
          <a
            href={href}
            aria-current={currentPath === href || (href === "/blog" && currentPath.startsWith("/blog")) ? "page" : undefined}
            class="px-3 py-1.5 text-sm font-medium rounded-lg text-muted-foreground hover:text-foreground hover:bg-muted transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring aria-[current=page]:text-primary aria-[current=page]:bg-primary/10"
          >
            <span aria-hidden="true" class="mr-1">{emoji}</span>{label}
          </a>
        ))}
      </nav>

      <div class="flex items-center gap-2">
        <!-- Dark mode toggle -->
        <button
          @click="$store.theme.toggle()"
          aria-label="Toggle dark mode"
          class="p-2 rounded-lg text-muted-foreground hover:text-foreground hover:bg-muted transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring"
        >
          <span x-show="!$store.theme.dark" aria-hidden="true">🌙</span>
          <span x-show="$store.theme.dark" aria-hidden="true" x-cloak>☀️</span>
        </button>

        <!-- Mobile hamburger -->
        <button
          @click="open = !open"
          :aria-expanded="open"
          aria-controls="mobile-menu"
          aria-label="Toggle navigation menu"
          class="md:hidden p-2 rounded-lg text-muted-foreground hover:text-foreground hover:bg-muted transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring"
        >
          <svg
            x-show="!open"
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <line x1="4" x2="20" y1="6" y2="6" /><line x1="4" x2="20" y1="12" y2="12" /><line x1="4" x2="20" y1="18" y2="18" />
          </svg>
          <svg
            x-show="open"
            x-cloak
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M18 6 6 18" /><path d="m6 6 12 12" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    x-show="open"
    x-cloak
    x-transition:enter="transition ease-out duration-200"
    x-transition:enter-start="opacity-0 -translate-y-2"
    x-transition:enter-end="opacity-100 translate-y-0"
    x-transition:leave="transition ease-in duration-150"
    x-transition:leave-start="opacity-100 translate-y-0"
    x-transition:leave-end="opacity-0 -translate-y-2"
    @click.outside="open = false"
    class="md:hidden border-t border-border/50 bg-background/95 backdrop-blur-md"
  >
    <nav aria-label="Mobile navigation" class="max-w-5xl mx-auto px-4 py-3 flex flex-col gap-1">
      {navLinks.map(({ href, label, emoji }) => (
        <a
          href={href}
          @click="open = false"
          aria-current={currentPath === href || (href === "/blog" && currentPath.startsWith("/blog")) ? "page" : undefined}
          class="px-3 py-2.5 text-sm font-medium rounded-lg text-muted-foreground hover:text-foreground hover:bg-muted transition-colors aria-[current=page]:text-primary aria-[current=page]:bg-primary/10"
        >
          <span aria-hidden="true" class="mr-2">{emoji}</span>{label}
        </a>
      ))}
    </nav>
  </div>
</header>
