---
import { awards } from "../lib/data";
---

<section id="awards" class="py-12 md:py-16 scroll-mt-20">
  <div class="max-w-5xl mx-auto px-4 md:px-6">
    <h2
      class="scroll-reveal text-2xl md:text-3xl font-display mb-8 text-foreground"
     
    >
      <span class="text-highlight">Awards</span>
    </h2>

    <div class="flex flex-wrap gap-4">
      {awards.map((award, i) => (
        <div
          class={`scroll-reveal scroll-reveal-delay-${i + 1} w-full md:w-max flex items-center gap-4 px-6 py-4 rounded-2xl bg-card border border-border hover:border-primary/30 transition-colors`}
        >
          <span class="text-2xl" aria-hidden="true">🏆</span>
          <div class="flex flex-col">
            <span class="text-2xl font-display text-primary leading-none">{award.name}</span>
            <span class="pt-1 text-sm text-muted-foreground mt-1">{award.issuer} · {award.date} </span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
